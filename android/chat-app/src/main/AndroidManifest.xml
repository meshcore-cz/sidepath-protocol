<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- BLE/foreground-service permissions and the BLEEdgeService are declared in the
         :common library manifest and merged in. -->
    <application
        android:name="cz.arnal.bleedge.chat.ChatApp"
        android:label="BLEEdge Chat"
        android:supportsRtl="true"
        android:theme="@style/Theme.BLEEdgeChat">
        <activity
            android:name="cz.arnal.bleedge.chat.ChatActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
